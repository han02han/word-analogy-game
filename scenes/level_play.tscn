[gd_scene load_steps=2 format=3]

[ext_resource type="Script" path="res://scripts/ui/puzzle_ui.gd" id="1"]

[node name="LevelPlay" type="Control"]
layout_mode = 3
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
script = ExtResource("1")

[node name="Background" type="ColorRect" parent="."]
layout_mode = 0
offset_right = 1280.0
offset_bottom = 720.0
color = Color(1.0, 0.97, 0.92, 1)

; ---- 顶部栏 ----
[node name="TopBar" type="HBoxContainer" parent="."]
layout_mode = 1
anchors_preset = 1
anchor_left = 0.0
anchor_right = 1.0
offset_left = 16.0
offset_top = 12.0
offset_right = -16.0
offset_bottom = 52.0
grow_horizontal = 2

[node name="BackBtn" type="Button" parent="TopBar"]
layout_mode = 2
text = "← 返回"
custom_minimum_size = Vector2(80, 40)

[node name="LevelTitle" type="Label" parent="TopBar"]
layout_mode = 2
text = "第 1 关"
horizontal_alignment = 1
size_flags_horizontal = 3
theme_override_font_sizes/font_size = 24

[node name="HintBtn" type="Button" parent="TopBar"]
layout_mode = 2
text = "💡"
custom_minimum_size = Vector2(60, 40)

[node name="HintLabel" type="Label" parent="TopBar"]
layout_mode = 2
text = "× 3"
vertical_alignment = 1
theme_override_font_sizes/font_size = 16

; ---- 插图区域 ----
[node name="IllustrationArea" type="Control" parent="."]
layout_mode = 1
anchors_preset = 5
anchor_left = 0.5
anchor_right = 0.5
offset_left = -220.0
offset_top = 70.0
offset_right = 220.0
offset_bottom = 320.0
grow_horizontal = 2

[node name="IllustrationBefore" type="TextureRect" parent="IllustrationArea"]
layout_mode = 0
offset_right = 440.0
offset_bottom = 250.0
expand_mode = 1
stretch_mode = 1

[node name="IllustrationAfter" type="TextureRect" parent="IllustrationArea"]
layout_mode = 0
offset_right = 440.0
offset_bottom = 250.0
expand_mode = 1
stretch_mode = 1
visible = false

; ---- 谜题文字 ----
[node name="PuzzleLabel" type="Label" parent="."]
layout_mode = 1
anchors_preset = 5
anchor_left = 0.5
anchor_right = 0.5
offset_left = -400.0
offset_top = 340.0
offset_right = 400.0
offset_bottom = 380.0
grow_horizontal = 2
text = "巴黎 − 法国 + 西班牙 = ？"
horizontal_alignment = 1
theme_override_font_sizes/font_size = 28
theme_override_colors/font_color = Color(0.15, 0.15, 0.15, 1)

; ---- 候选字池 ----
[node name="CandidatesContainer" type="GridContainer" parent="."]
layout_mode = 1
anchors_preset = 5
anchor_left = 0.5
anchor_right = 0.5
offset_left = -280.0
offset_top = 400.0
offset_right = 280.0
offset_bottom = 500.0
grow_horizontal = 2
columns = 6
theme_override_constants/h_separation = 10
theme_override_constants/v_separation = 10

; ---- 答案槽 ----
[node name="AnswerSection" type="VBoxContainer" parent="."]
layout_mode = 1
anchors_preset = 5
anchor_left = 0.5
anchor_right = 0.5
offset_left = -200.0
offset_top = 520.0
offset_right = 200.0
offset_bottom = 560.0
grow_horizontal = 2

[node name="AnswerLabel" type="Label" parent="AnswerSection"]
layout_mode = 2
text = "你的答案："
horizontal_alignment = 1
theme_override_font_sizes/font_size = 16

[node name="SlotsContainer" type="HBoxContainer" parent="AnswerSection"]
layout_mode = 2
alignment = 1
theme_override_constants/separation = 8

; ---- 确认按钮 ----
[node name="ConfirmBtn" type="Button" parent="."]
layout_mode = 1
anchors_preset = 5
anchor_left = 0.5
anchor_right = 0.5
offset_left = -100.0
offset_top = 600.0
offset_right = 100.0
offset_bottom = 656.0
grow_horizontal = 2
text = "确认"
custom_minimum_size = Vector2(200, 56)
disabled = true

; ---- 信号连接 ----
[connection signal="pressed" from="TopBar/BackBtn" to="." method="_on_back_pressed"]
[connection signal="pressed" from="TopBar/HintBtn" to="." method="_on_hint_pressed"]
[connection signal="pressed" from="ConfirmBtn" to="." method="_on_confirm_pressed"]
